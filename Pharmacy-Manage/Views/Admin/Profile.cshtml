@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model Pharmacy_Manage.Models.User

@{
    var firstName = Model.FullName?.Split(' ')[0];
}

<h3 class="mb-4">Admin Profile</h3>

<div class="card shadow">

    <div class="card-body">

        <div class="text-center mb-4">

            <img src="~/images/profile.png"
                 width="100"
                 height="100"
                 class="rounded-circle border shadow-sm" />

            <h4 class="mt-3">@firstName</h4>

        </div>

        <table class="table table-bordered">

            <tr>
                <th>Full Name</th>
                <td>@Model.FullName</td>
            </tr>

            <tr>
                <th>Email</th>
                <td>
                    @Model.Email

                    <a asp-controller="Admin"
                           asp-action="ChangeEmail"
                           class="btn btn-sm btn-primary ms-2">
                        Change
                    </a>
                </td>
            </tr>

            <tr>
                <th>Role</th>
                <td>@Model.Role</td>
            </tr>

            <tr>
                <th>Status</th>
                <td>@Model.Status</td>
            </tr>

            <tr>
                <th>Created At</th>
                <td>@Model.CreatedAt.ToString("dd MMM yyyy")</td>
            </tr>

        </table>

    </div>

</div>