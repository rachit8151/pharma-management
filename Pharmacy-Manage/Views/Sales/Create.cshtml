@{
    Layout = "~/Views/Shared/_PharmacistLayout.cshtml";
}

<h2>Add Daily Sale</h2>

<form method="post">

    <div class="mb-3">
        <label>Medicine</label>
        <select id="medicineDropdown" name="MedicineId" class="form-control">
            <option value="">-- Select Medicine --</option>
            @foreach (var item in ViewBag.Medicines)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Unit Price</label>
        <input type="text" id="price" name="UnitPrice" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label>Quantity</label>
        <input type="number" id="quantity" name="QuantitySold" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Total Amount</label>
        <input type="text" id="total" name="TotalAmount" class="form-control" readonly />
    </div>

    <button type="submit" class="btn btn-primary">Save Sale</button>

</form>

<!-- ✅ External JS -->
<script src="~/js/sales-create.js"></script>