@{
    Layout = "~/Views/Shared/_PharmacistLayout.cshtml";
}

@model List<Pharmacy_Manage.Models.MedicineRequest>

<h2>My Medicine Requests</h2>

<table class="table table-bordered table-striped">

    <tr>
        <th>Medicine</th>
        <th>Quantity</th>
        <th>Status</th>
        <th>Request Date</th>
        <th>Track</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>

            <td>@item.Medicine.MedicineName</td>

            <td>@item.Quantity</td>

            <td>

                @if (item.Status == "pending")
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
                else if (item.Status == "approved")
                {
                    <span class="badge bg-primary">Approved</span>
                }
                else if (item.Status == "dispatch")
                {
                    <span class="badge bg-info text-dark">Dispatch</span>
                }
                else if (item.Status == "paid")
                {
                    <span class="badge bg-secondary">Paid</span>
                }
                else if (item.Status == "delivered")
                {
                    <span class="badge bg-success">Delivered</span>
                }
                else
                {
                    <span class="badge bg-danger">Rejected</span>
                }

            </td>

            <td>@item.RequestDate.ToString("dd-MM-yyyy HH:mm")</td>

            <td>

                <button class="btn btn-sm btn-dark"
                        data-bs-toggle="collapse"
                        data-bs-target="#track_@item.RequestId">
                    Track
                </button>

            </td>

        </tr>

        <tr class="collapse" id="track_@item.RequestId">

            <td colspan="5">

                <div class="p-3 bg-light border rounded">

                    <h6>Request Tracking</h6>

                    <ul class="list-group">

                        <li class="list-group-item
                            @(item.Status == "pending" || item.Status == "approved" || item.Status == "dispatch" || item.Status == "paid" || item.Status == "delivered" ? "list-group-item-success" : "")">
                            ✅ Request Submitted
                        </li>

                        <li class="list-group-item
                            @(item.Status == "approved" || item.Status == "dispatch" || item.Status == "paid" || item.Status == "delivered" ? "list-group-item-success" : "")">
                            ✅ Approved by Admin
                        </li>

                        <li class="list-group-item
                            @(item.Status == "dispatch" || item.Status == "paid" || item.Status == "delivered" ? "list-group-item-success" : "")">
                            🚚 Medicine Dispatch
                        </li>

                        <li class="list-group-item
                            @(item.Status == "paid" || item.Status == "delivered" ? "list-group-item-success" : "")">
                            💳 Payment Completed
                        </li>

                        <li class="list-group-item
                            @(item.Status == "delivered" ? "list-group-item-success" : "")">
                            📦 Delivered Successfully
                        </li>

                    </ul>

                    <div class="mt-3">

                        <strong>Expiry Date:</strong>

                        @if (item.ExpiryDate != null)
                        {
                            <span class="text-success">
                                @item.ExpiryDate.Value.ToString("dd MMM yyyy")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Not Assigned</span>
                        }

                    </div>

                    @if (!string.IsNullOrEmpty(item.RejectReason))
                    {
                        <div class="mt-2 text-danger">
                            <strong>Reject Reason:</strong> @item.RejectReason
                        </div>
                    }

                </div>

            </td>

        </tr>
    }

</table>